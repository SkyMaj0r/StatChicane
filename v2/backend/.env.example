# =============================================================================
# StatChicane v2 — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to git.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# Full SQLAlchemy connection URL for the MySQL / F1DB instance.
# Format: mysql+mysqlconnector://<user>:<password>@<host>:<port>/<dbname>
# -----------------------------------------------------------------------------
DATABASE_URL=mysql+mysqlconnector://user:password@localhost:3306/f1db

# -----------------------------------------------------------------------------
# Redis
# Connection URL for the Redis cache.
# Default points to a local Redis instance on the standard port.
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Google Gemini API
# API key obtained from https://aistudio.google.com/app/apikey
# -----------------------------------------------------------------------------
GEMINI_API_KEY=your-gemini-api-key-here

# Which Gemini model variant to use for NLP queries.
GEMINI_MODEL=gemini-2.0-flash

# -----------------------------------------------------------------------------
# JWT Authentication
# A long, random secret string used to sign and verify JWT tokens.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
# -----------------------------------------------------------------------------
JWT_SECRET=your-strong-jwt-secret-here

# Signing algorithm — HS256 is the recommended symmetric choice.
JWT_ALGORITHM=HS256

# Number of minutes before a token expires.
JWT_EXPIRY_MINUTES=60

# -----------------------------------------------------------------------------
# CORS
# Comma-separated list of allowed frontend origins.
# Add your production domain here when deploying.
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# FastF1 Telemetry Cache
# Local directory where FastF1 will cache downloaded telemetry data.
# Ensure this path exists or FastF1 will create it on first use.
# -----------------------------------------------------------------------------
FASTF1_CACHE_PATH=./fastf1_cache
